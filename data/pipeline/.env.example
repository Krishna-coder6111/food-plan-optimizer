# BLS API key — register at https://data.bls.gov/registrationEngine/
# Required only if using the v2 API endpoint (process_bls.py downloads
# flat files directly and doesn't need a key, but the v2 timeseries
# endpoint does — used for finer-grained multi-series queries).
BLS_API_KEY=

# USDA FoodData Central key — sign up at https://fdc.nal.usda.gov/api-key-signup.html
# DEMO_KEY works at low rate limits.
USDA_API_KEY=DEMO_KEY
